{
	"name": "n8n-nodes-playwright-cdp",
	"version": "0.1.0",
	"description": "n8n node for controlling CloakBrowser over CDP with native CloakBrowser humanization",
	"license": "MIT",
	"homepage": "https://github.com/cybersardinha/n8n-nodes-cloakbrowser-cdp",
	"keywords": [
		"n8n-community-node-package",
		"playwright",
		"cdp",
		"cloakbrowser",
		"browser-automation",
		"antidetect"
	],
	"author": {
		"name": "Bogdan"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/cybersardinha/n8n-nodes-cloakbrowser-cdp.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": false,
		"credentials": [],
		"nodes": [
			"dist/nodes/PlaywrightCdp/PlaywrightCdp.node.js"
		]
	},
	"dependencies": {
		"cloakbrowser": "0.4.10",
		"playwright-core": "1.61.0"
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"@types/node": "^20.10.0",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"publishConfig": {
		"access": "public"
	}
}
